{
  "version": 2,
  "builds": [{ "src": "index.html", "use": "@vercel/static-build", "config": { "distDir": "dist" } }],
  "routes": [
    { "src": "/(.*)\\.(js|css|svg|png|jpg|jpeg|gif|ico|woff2?)", "headers": { "cache-control": "public, max-age=31536000, immutable" } },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}